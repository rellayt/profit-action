# Backend (copy to backend/.env)
# Live AI when OPENAI_API_KEY is set AND DEMO_MODE=false
# DEMO_MODE=true forces local heuristics even with a key
DEMO_MODE=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=60

# CORS · frontend Vite
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend Vite proxy target (optional · defaults to http://127.0.0.1:8000)
# Used only by vite.config.ts — never bundle secrets into the client.
VITE_BACKEND_URL=
